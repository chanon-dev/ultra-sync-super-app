{
  "permissions": {
    "allow": [
      "Bash(GONOSUMDB='github.com/chanon/*' GOFLAGS='-mod=mod' go work sync)",
      "Bash(GONOSUMDB='*' GOPRIVATE='github.com/chanon/*' go work sync)",
      "Bash(GOPROXY=off go work sync)",
      "Bash(GONOSUMDB='*' go work sync)",
      "Bash(GOWORK=off GONOSUMDB='*' go mod tidy)",
      "Bash(GOWORK=off go build ./...)",
      "Bash(GONOSUMDB='*' go build github.com/chanon/ultra-sync/services/logistics/...)",
      "Bash(flutter analyze *)",
      "Bash(which flutter *)",
      "Read(//opt/homebrew/bin/**)",
      "Bash(curl -L \"https://github.com/rsms/inter/releases/download/v4.0/Inter-4.0.zip\" -o inter.zip)",
      "Bash(unzip -j inter.zip \"Inter Desktop/Inter-Regular.otf\" \"Inter Desktop/Inter-Medium.otf\" \"Inter Desktop/Inter-SemiBold.otf\" \"Inter Desktop/Inter-Bold.otf\" -d .)",
      "Bash(rm inter.zip)",
      "Bash(unzip -l inter.zip)"
    ]
  }
}
